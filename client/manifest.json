{
  "manifest_version": 3,
  "name": "AI-CodeBuddy",
  "version": "1.0",
  "description": "AI assistant for DSA hints, debugging, and progress tracking",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["https://leetcode.com/*", "http://localhost:5000/*"],

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "index.html",
    "default_icon": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
  },

  "content_scripts": [
    {
      "js": ["src/pageBridge.js"],
      "matches": ["https://leetcode.com/*"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": ["src/contentScript.jsx"],  
      "matches": ["https://leetcode.com/*"],
      "run_at": "document_idle"
    }
  ],
 
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }

  
}
